{
  "$schema": "https://opencode.ai/config.json",
  "model": "tenefic-llm/gpt-5.4",
  "small_model": "tenefic-llm/gpt-5.4-mini",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "figma-mcp-go": {
      "type": "local",
      "command": ["npx", "-y", "@vkhanhqui/figma-mcp-go@latest"]
    }
  },
  "provider": {
    "tenefic": {
      "name": "Tenefic Provider",
      "options": {
        "baseURL": "{env:TENEFIC_BASE_URL}",
        "apiKey": "{env:TENEFIC_API_KEY}"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT 5.4 (1M Context)",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25
          },
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
